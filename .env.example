# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Authentication
JWT_SECRET=change-this-to-a-secure-random-string
API_KEY=change-this-to-a-secure-api-key

# Database
DATABASE_URL=file:./teleflow.db

# Redis (Optional)
# REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info

# Session
SESSION_ENCRYPTION_KEY=change-this-32-char-encryption-key

# Telegram API Credentials
# Get from https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# CORS
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
